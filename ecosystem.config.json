{
  "apps": [
    {
      "name": "holonet",
      "script": "npm",
      "args": "start",
      "interpreter": "none",
      "watch": false,
      "autorestart": true,
      "max_restarts": 5,
      "restart_delay": 2000,
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "out_file": "./logs/holonet.out.log",
      "error_file": "./logs/holonet.err.log"
    }
  ]
}
